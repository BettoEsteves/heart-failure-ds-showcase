# MCP configuration template (do not commit real secrets)
# Copy to `.env.mcp.local` (recommended) or set as environment variables in your IDE/OS/CI.
# `.env.mcp.local` is ignored by Git and is the right place for each user to put their own values.

# Project identity (required per cloned project)
PROJECT_NAME=replace-with-project-name

# Jira MCP
JIRA_MCP_URL=https://replace-with-jira-mcp-endpoint.example/mcp
JIRA_MCP_TOKEN=replace-with-jira-token
JIRA_WORKSPACE=replace-with-jira-workspace

# Azure DevOps MCP
AZURE_MCP_URL=https://replace-with-azure-mcp-endpoint.example/mcp
AZURE_MCP_TOKEN=replace-with-azure-token
AZURE_ORG=replace-with-azure-org
AZURE_PROJECT=replace-with-azure-project

# Figma MCP
FIGMA_MCP_URL=https://replace-with-figma-mcp-endpoint.example/mcp
FIGMA_MCP_TOKEN=replace-with-figma-token
FIGMA_TEAM=replace-with-figma-team-or-workspace

# Notion MCP
NOTION_MCP_URL=https://replace-with-notion-mcp-endpoint.example/mcp
NOTION_MCP_TOKEN=replace-with-notion-token
NOTION_WORKSPACE=replace-with-notion-workspace

# Optional shared controls
MCP_MODE=remote

# Optional Docker compose image/port overrides (only if using `infra/ci/docker-compose.mcp.yml`)
# Important: these values are placeholders. Replace with real images from your MCP providers.
JIRA_MCP_IMAGE=ghcr.io/replace-with-your-org/jira-mcp:latest
JIRA_MCP_PORT=7810
AZURE_MCP_IMAGE=ghcr.io/replace-with-your-org/azure-devops-mcp:latest
AZURE_MCP_PORT=7811
FIGMA_MCP_IMAGE=ghcr.io/replace-with-your-org/figma-mcp:latest
FIGMA_MCP_PORT=7812
NOTION_MCP_IMAGE=ghcr.io/replace-with-your-org/notion-mcp:latest
NOTION_MCP_PORT=7813
